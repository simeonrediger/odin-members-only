<div class="message">
  <div class="message-header">
    <div class="message-heading">
      <h2 class="message-title"><%= message.title %></h2>
      <% if (locals.currentUser?.role === USER_ROLES.ADMIN) { %>
        <form action="/message/<%= message.id %>?_method=DELETE" method="post">
          <button type="submit" class="delete-button">Delete</button>
        </form>
      <% } %>
    </div>
    <% if (locals.currentUser?.role) { %>
      <div class="message-info">
        <p>by <%= message.author.display_name ?? message.author.username %></p>
        <p
          data-time="<%= message.time.toISOString() %>"
          class="message-time"
        ></p>
      </div>
    <% } %>
  </div>
  <p class="message-content"><%= message.content %></p>
</div>
