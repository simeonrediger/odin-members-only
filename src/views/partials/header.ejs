<header class="header">
  <h1><%= pageName %></h1>
  <nav>
    <ul class="navbar-list">
      <% if (locals.currentUser?.role === USER_ROLES.ADMIN) { %>
        <li><a href="/log-out">Log out</a></li>
      <% } else if (locals.currentUser?.role === USER_ROLES.MEMBER) { %>
        <li><a href="/admin">Admin access</a></li>
        <li><a href="/log-out">Log out</a></li>
      <% } else if (locals.currentUser) { %>
        <li><a href="/member">Member access</a></li>
        <li><a href="/log-out">Log out</a></li>
      <% } else { %>
        <li><a href="/sign-up">Sign up</a></li>
        <li><a href="/log-in">Log in</a></li>
      <% } %>
    </ul>
  </nav>
</header>
