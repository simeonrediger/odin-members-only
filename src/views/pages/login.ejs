<% const pageName = 'Log in'; %>
<%- include('../partials/layout-start', { pageName }) %>
<%- include('../partials/header', { pageName }) %>

<form action="/log-in" method="post" class="standard-form">
  <label for="username">Username</label>
  <input
    type="text"
    name="username"
    id="username"
    autocomplete="username"
    required
  />

  <label for="password">Password</label>
  <input
    type="password"
    name="password"
    id="password"
    autocomplete="current-password"
    required
  />

  <%- include('../partials/form-errors', { errors: flashMessages }) %>

  <div class="cancel-submit-buttons">
    <a href="/" class="cancel-button button">Cancel</a>
    <button type="submit">Log in</button>
  </div>
</form>

<%- include('../partials/layout-end') %>
